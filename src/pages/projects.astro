---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.jsx";
import ScrollToTop from "../components/ScrollToTop.jsx";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Footer from "../components/Footer.astro";
import projectsData from "../data/projects.json";
import { RiArrowLeftLine } from "react-icons/ri";
---

<Layout title="Projects — Trung Kien">
  <Navbar client:load pathname="/projects" />
  <ScrollToTop client:idle />

  <main class="projects-page">
    <div class="container">
      <SectionHeading as="h1" id="all-projects-heading">All Projects</SectionHeading>

      <div class="projects-page-meta">
        <span class="projects-page-count">
          Count: {String(projectsData.length).padStart(2, "0")}
        </span>
      </div>

      <div class="projects-page-grid">
        {projectsData.map((project, i) => <ProjectCard project={project} index={i} />)}
      </div>

      <div class="projects-page-cta">
        <a class="btn-brutal-light reveal" href="/">
          <RiArrowLeftLine size={18} />
          Back home
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .projects-page {
    padding-top: 96px;
    padding-bottom: 4rem;
  }
  .projects-page-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 2rem;
  }
  .projects-page-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .projects-page-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .projects-page-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .btn-brutal-light {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #FFF;
    color: #000;
    border: 2px solid #000;
    box-shadow: var(--shadow-brutal);
    padding: 12px 20px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.12s ease-out;
    text-decoration: none;
  }
  .btn-brutal-light:hover {
    background: #000;
    color: #FFF;
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-brutal-lg);
  }
  .btn-brutal-light:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }
  @media (min-width: 768px) {
    .projects-page {
      padding-top: 120px;
      padding-bottom: 6rem;
    }
    .projects-page-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .projects-page-cta { margin-top: 3.5rem; }
    .btn-brutal-light { padding: 16px 28px; font-size: 1rem; }
  }
</style>
