---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Header from "../components/Header.jsx";
import Technology from "../components/Technology.jsx";
import SectionHeading from "../components/SectionHeading.astro";
import Connect from "../components/Connect.astro";
import ExperienceFeed from "../components/ExperienceFeed.astro";
import ProjectsFeed from "../components/ProjectsFeed.astro";
import RecentWriting from "../components/RecentWriting.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Navbar />
  <main>
    <Header />

    <ExperienceFeed />

    <ProjectsFeed />

    <RecentWriting />

    <section id="tech" aria-labelledby="tech-heading" class="tech-section">
      <div class="container">
        <SectionHeading id="tech-heading" index={4}>Tech</SectionHeading>
        <Technology />
      </div>
    </section>

    <Connect />

    <Footer />
  </main>
</Layout>

<style>
  .tech-section {
    padding-top: 3rem;
    padding-bottom: 3rem;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }
  @media (min-width: 768px) {
    .tech-section { padding-top: 4.5rem; padding-bottom: 4.5rem; }
  }
</style>
