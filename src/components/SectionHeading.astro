---
export interface Props {
  id?: string;
  index?: number;
  as?: "h1" | "h2" | "h3";
}

const { id, index, as = "h2" } = Astro.props;
const Tag = as;
---

<div class="section-heading">
  <div class="section-heading-row">
    {
      index !== undefined && (
        <span class="section-heading-index">{String(index).padStart(2, "0")} /</span>
      )
    }
    <Tag id={id} class="section-heading-text">
      <slot />
    </Tag>
  </div>
  <div class="section-heading-bar" aria-hidden="true"></div>
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    border-bottom: 2px solid var(--border);
    padding-bottom: 14px;
  }
  .section-heading-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .section-heading-index {
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }
  .section-heading-text {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin: 0;
    font-weight: 700;
  }
  .section-heading-bar {
    margin-top: 8px;
    height: 6px;
    width: 120px;
    background: var(--fg);
  }
  @media (min-width: 768px) {
    .section-heading { margin-bottom: 2rem; }
    .section-heading-index { font-size: 1rem; }
  }
</style>
