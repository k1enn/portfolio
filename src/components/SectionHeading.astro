---
export interface Props {
  id?: string;
  index?: number;
  as?: "h1" | "h2" | "h3";
}

const { id, index, as = "h2" } = Astro.props;
const Tag = as;
---

<div class="section-heading">
  <div class="section-heading-row">
    {
      index !== undefined && (
        <span class="section-heading-index">{String(index).padStart(2, "0")} /</span>
      )
    }
    <Tag id={id} class="section-heading-text reveal-left">
      <slot />
    </Tag>
  </div>
  <div class="section-heading-bar reveal-underline" aria-hidden="true"></div>
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 2rem;
    border-bottom: 2px solid #000;
    padding-bottom: 16px;
  }
  .section-heading-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .section-heading-index {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #737373;
    letter-spacing: 0.1em;
  }
  .section-heading-text {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #000;
    text-transform: uppercase;
    margin: 0;
  }
  .section-heading-bar {
    margin-top: 8px;
    height: 6px;
    background: #000;
  }
  @media (min-width: 768px) {
    .section-heading { margin-bottom: 3rem; }
    .section-heading-index { font-size: 1rem; }
  }
</style>
