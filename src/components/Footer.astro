---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-row">
      <div class="footer-brand">
        <span class="footer-dot" aria-hidden="true"></span>
        <span class="footer-logo">k1en / Trung Kien</span>
      </div>
      <div class="footer-meta">
        <span>© {currentYear}</span>
        <span>Built with Astro</span>
        <span>Hanoi, VN</span>
      </div>
    </div>

    <div class="footer-game-wrap" aria-label="Dinosaur game">
      <p class="footer-game-hint">// Press Space or tap to jump</p>
      <div id="main-frame-error" class="interstitial-wrapper" tabindex="0">
        <div id="main-content">
          <div class="icon icon-offline" alt="" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>

  <img id="offline-resources-1x" src="/trex/sprite-1x.png" alt="" hidden aria-hidden="true" />
  <img id="offline-resources-2x" src="/trex/sprite-2x.png" alt="" hidden aria-hidden="true" />
</footer>

<script is:inline src="/trex/trex.js"></script>

<script is:inline>
  (function () {
    if (typeof Runner === "undefined") return;

    function hexToRgb(h) {
      h = (h || "").trim().replace("#", "");
      if (h.length === 3) h = h.split("").map(function (c) { return c + c; }).join("");
      if (h.length !== 6) return [26, 26, 26];
      return [
        parseInt(h.slice(0, 2), 16),
        parseInt(h.slice(2, 4), 16),
        parseInt(h.slice(4, 6), 16),
      ];
    }

    function readVar(name, fallback) {
      var v = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      return v || fallback;
    }

    function recolor(img) {
      var ink = hexToRgb(readVar("--fg", "#1a1a1a"));
      var paper = hexToRgb(readVar("--bg", "#f0f0f0"));
      var c = document.createElement("canvas");
      c.width = img.naturalWidth;
      c.height = img.naturalHeight;
      var ctx = c.getContext("2d");
      ctx.drawImage(img, 0, 0);
      var d = ctx.getImageData(0, 0, c.width, c.height);
      var px = d.data;
      for (var i = 0; i < px.length; i += 4) {
        if (px[i + 3] === 0) continue;
        var lum = 0.299 * px[i] + 0.587 * px[i + 1] + 0.114 * px[i + 2];
        var t = lum < 128 ? ink : paper;
        px[i] = t[0];
        px[i + 1] = t[1];
        px[i + 2] = t[2];
      }
      ctx.putImageData(d, 0, 0);
      c.complete = true;
      return c;
    }

    Runner.prototype.loadSounds = function () { this.audioContext = null; };
    Runner.prototype.setArcadeMode = function () {};
    Runner.prototype.setArcadeModeContainerScale = function () {};

    Runner.prototype.loadImages = function () {
      var self = this;
      var isHidpi = window.devicePixelRatio > 1;
      self.spriteDef = isHidpi ? Runner.spriteDefinition.HDPI : Runner.spriteDefinition.LDPI;
      var imgEl = document.getElementById(
        isHidpi ? "offline-resources-2x" : "offline-resources-1x"
      );

      function ready() {
        Runner.imageSprite = recolor(imgEl);
        self.init();
      }

      if (imgEl.complete && imgEl.naturalWidth > 0) ready();
      else imgEl.addEventListener("load", ready, { once: true });
    };

    function refreshSprite() {
      var inst = Runner.instance_;
      if (!inst) return;
      var isHidpi = window.devicePixelRatio > 1;
      var imgEl = document.getElementById(
        isHidpi ? "offline-resources-2x" : "offline-resources-1x"
      );
      if (!imgEl || !imgEl.complete) return;
      Runner.imageSprite = recolor(imgEl);
    }

    new MutationObserver(refreshSprite).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
    var mq = window.matchMedia("(prefers-color-scheme: dark)");
    if (mq.addEventListener) mq.addEventListener("change", refreshSprite);
    else if (mq.addListener) mq.addListener(refreshSprite);
  })();
</script>

<style>
  .site-footer {
    background: var(--bg);
    color: var(--fg);
    border-top: 2px solid var(--border);
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  .footer-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-brand { display: flex; align-items: center; gap: 12px; }
  .footer-dot {
    display: inline-block;
    width: 14px;
    height: 14px;
    background: var(--fg);
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  .footer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .footer-game-wrap {
    margin-top: 2rem;
    border-top: 2px solid var(--border);
    padding-top: 1.5rem;
  }
  .footer-game-hint {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .interstitial-wrapper {
    width: 100%;
    max-width: 600px;
    height: 150px;
    margin: 0 auto;
    outline: none;
    position: relative;
    overflow: hidden;
  }
  #main-content { display: none; }
  @media (min-width: 768px) {
    .site-footer { padding-top: 2.5rem; padding-bottom: 2.5rem; }
    .footer-row { flex-direction: row; align-items: center; }
    .footer-logo { font-size: 1.5rem; }
  }
</style>

<style is:global>

</style>
