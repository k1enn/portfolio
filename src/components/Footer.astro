---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-row">
      <div class="footer-brand">
        <span class="footer-dot" aria-hidden="true"></span>
        <span class="footer-logo">k1en / Trung Kien</span>
      </div>
      <div class="footer-meta">
        <span>© {currentYear}</span>
        <span>Built with Astro</span>
        <span>Hanoi, VN</span>
      </div>
    </div>

    <div class="footer-game-wrap" aria-label="Dinosaur game">
      <p class="footer-game-hint">// Press Space or tap to jump</p>
      <div id="main-frame-error" class="interstitial-wrapper" tabindex="0">
        <div id="main-content">
          <div class="icon icon-offline" alt="" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>

  <img id="offline-resources-1x" src="/trex/sprite-1x.png" alt="" hidden aria-hidden="true" />
  <img id="offline-resources-2x" src="/trex/sprite-2x.png" alt="" hidden aria-hidden="true" />
</footer>

<script is:inline src="/trex/trex.js"></script>

<script is:inline>
  (function () {
    if (typeof Runner === "undefined") return;
    Runner.prototype.loadSounds = function () { this.audioContext = null; };
    Runner.prototype.setArcadeMode = function () {};
    Runner.prototype.setArcadeModeContainerScale = function () {};
  })();
</script>

<style>
  .site-footer {
    background: var(--bg);
    color: var(--fg);
    border-top: 2px solid var(--border);
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  .footer-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-brand { display: flex; align-items: center; gap: 12px; }
  .footer-dot {
    display: inline-block;
    width: 14px;
    height: 14px;
    background: var(--fg);
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  .footer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .footer-game-wrap {
    margin-top: 2rem;
    border-top: 2px solid var(--border);
    padding-top: 1.5rem;
  }
  .footer-game-hint {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .interstitial-wrapper {
    width: 100%;
    height: 150px;
    margin: 0 auto;
    outline: none;
    position: relative;
    overflow: hidden;
  }
  #main-content { display: none; }
  @media (min-width: 768px) {
    .site-footer { padding-top: 2.5rem; padding-bottom: 2.5rem; }
    .footer-row { flex-direction: row; align-items: center; }
    .footer-logo { font-size: 1.5rem; }
  }
</style>

<style is:global>
  .runner-container {
    position: absolute;
    top: 0;
    left: 0;
    height: 150px;
    overflow: hidden;
  }
  .runner-canvas {
    display: block;
    image-rendering: pixelated;
  }
  :root[data-theme="dark"] .runner-canvas { filter: invert(1); }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .runner-canvas { filter: invert(1); }
  }
  body.inverted .runner-canvas { filter: invert(1); }
  :root[data-theme="dark"] body.inverted .runner-canvas { filter: none; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) body.inverted .runner-canvas { filter: none; }
  }
  .interstitial-wrapper .controller {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    background: transparent;
    cursor: pointer;
  }
</style>
