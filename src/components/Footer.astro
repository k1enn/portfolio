---
import { FaGithub, FaLinkedin, FaYoutube } from "react-icons/fa";

const YEAR = new Date().getFullYear();
const SOCIALS = [
  { url: "https://github.com/k1enn", Icon: FaGithub, label: "GitHub" },
  { url: "https://linkedin.com/in/k1enn", Icon: FaLinkedin, label: "LinkedIn" },
  { url: "https://www.youtube.com/@iamk1en", Icon: FaYoutube, label: "YouTube" },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <section class="footer-game-wrap" aria-label="Dinosaur game">
      <div id="main-frame-error" class="interstitial-wrapper" tabindex="0">
        <div id="main-content">
          <div class="icon icon-offline" aria-hidden="true"></div>
        </div>
      </div>
    </section>

    <div class="footer-meta">
      <span class="footer-copy">Trung Kien · © {YEAR}</span>
      <ul class="footer-socials">
        {SOCIALS.map(({ url, Icon, label }) => (
          <li>
            <a
              class="footer-social"
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${label} (opens in new tab)`}
            >
              <Icon aria-hidden="true" />
            </a>
          </li>
        ))}
      </ul>
      <span class="footer-built">Built with Astro</span>
    </div>
  </div>

  <img id="offline-resources-1x" src="/trex/sprite-1x.png" alt="" hidden aria-hidden="true" />
  <img id="offline-resources-2x" src="/trex/sprite-2x.png" alt="" hidden aria-hidden="true" />
</footer>

<script is:inline>
  (function () {
    var wrap = document.querySelector(".footer-game-wrap");
    if (!wrap) return;
    var loaded = false;
    var load = function () {
      if (loaded) return;
      loaded = true;
      var s = document.createElement("script");
      s.src = "/trex/trex.js";
      s.async = true;
      s.onload = function () {
        if (typeof Runner === "undefined") return;
        Runner.prototype.loadSounds = function () { this.audioContext = null; };
        Runner.prototype.setArcadeMode = function () {};
        Runner.prototype.setArcadeModeContainerScale = function () {};
        var scrollKeys = { 32: 1, 33: 1, 34: 1, 38: 1, 40: 1 };
        window.addEventListener("keydown", function (e) {
          var inst = Runner.instance_;
          if (!inst || !inst.activated || inst.crashed) return;
          if (scrollKeys[e.keyCode]) e.preventDefault();
        }, { capture: true, passive: false });
        if (document.readyState !== "loading") {
          new Runner(".interstitial-wrapper");
        }
      };
      document.head.appendChild(s);
    };
    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            load();
            io.disconnect();
            break;
          }
        }
      }, { rootMargin: "200px" });
      io.observe(wrap);
    } else {
      window.addEventListener("load", load);
    }
  })();
</script>

<style>
  .site-footer {
    background: var(--bg);
    color: var(--fg);
    border-top: 1px solid var(--line);
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  .footer-game-wrap {
    padding-top: 0.5rem;
  }
  .footer-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 18px;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .footer-copy { color: var(--muted-strong); font-weight: 500; }
  .footer-built { margin-left: auto; }
  .footer-socials {
    display: flex;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-social {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--border);
    color: var(--fg);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .footer-social:hover,
  .footer-social:focus-visible {
    background: var(--fg);
    color: var(--bg);
    outline: none;
  }
  .footer-social svg { width: 16px; height: 16px; }
  @media (max-width: 480px) {
    .footer-built { margin-left: 0; width: 100%; }
  }
  .interstitial-wrapper {
    width: 100%;
    height: 150px;
    margin: 0 auto;
    outline: none;
    position: relative;
    overflow: hidden;
  }
  #main-content { display: none; }
  @media (min-width: 768px) {
    .site-footer { padding-top: 2.5rem; padding-bottom: 2.5rem; }
  }
</style>

<style is:global>
  .runner-container {
    position: absolute;
    top: 0;
    left: 0;
    height: 150px;
    overflow: hidden;
  }
  .runner-canvas {
    display: block;
    image-rendering: pixelated;
  }
  :root[data-theme="dark"] .runner-canvas { filter: invert(1); }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .runner-canvas { filter: invert(1); }
  }
  body.inverted .runner-canvas { filter: invert(1); }
  :root[data-theme="dark"] body.inverted .runner-canvas { filter: none; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) body.inverted .runner-canvas { filter: none; }
  }
  .interstitial-wrapper .controller {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    background: transparent;
    cursor: pointer;
  }
</style>
