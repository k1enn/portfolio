<footer class="site-footer">
  <div class="container footer-inner">
    <section class="footer-game-wrap" aria-label="Dinosaur game">
      <div id="main-frame-error" class="interstitial-wrapper" tabindex="0">
        <div id="main-content">
          <div class="icon icon-offline" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </div>

  <img id="offline-resources-1x" src="/trex/sprite-1x.png" alt="" hidden aria-hidden="true" />
  <img id="offline-resources-2x" src="/trex/sprite-2x.png" alt="" hidden aria-hidden="true" />
</footer>

<script is:inline>
  (function () {
    var wrap = document.querySelector(".footer-game-wrap");
    if (!wrap) return;
    var loaded = false;
    var load = function () {
      if (loaded) return;
      loaded = true;
      var s = document.createElement("script");
      s.src = "/trex/trex.js";
      s.async = true;
      s.onload = function () {
        if (typeof Runner === "undefined") return;
        Runner.prototype.loadSounds = function () { this.audioContext = null; };
        Runner.prototype.setArcadeMode = function () {};
        Runner.prototype.setArcadeModeContainerScale = function () {};
        var scrollKeys = { 32: 1, 33: 1, 34: 1, 38: 1, 40: 1 };
        window.addEventListener("keydown", function (e) {
          var inst = Runner.instance_;
          if (!inst || !inst.activated || inst.crashed) return;
          if (scrollKeys[e.keyCode]) e.preventDefault();
        }, { capture: true, passive: false });
        if (document.readyState !== "loading") {
          new Runner(".interstitial-wrapper");
        }
      };
      document.head.appendChild(s);
    };
    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            load();
            io.disconnect();
            break;
          }
        }
      }, { rootMargin: "200px" });
      io.observe(wrap);
    } else {
      window.addEventListener("load", load);
    }
  })();
</script>

<style>
  .site-footer {
    background: var(--bg);
    color: var(--fg);
    border-top: 1px solid var(--line);
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  .footer-game-wrap {
    padding-top: 0.5rem;
  }
  .interstitial-wrapper {
    width: 100%;
    height: 150px;
    margin: 0 auto;
    outline: none;
    position: relative;
    overflow: hidden;
  }
  #main-content { display: none; }
  @media (min-width: 768px) {
    .site-footer { padding-top: 2.5rem; padding-bottom: 2.5rem; }
  }
</style>

<style is:global>
  .runner-container {
    position: absolute;
    top: 0;
    left: 0;
    height: 150px;
    overflow: hidden;
  }
  .runner-canvas {
    display: block;
    image-rendering: pixelated;
  }
  :root[data-theme="dark"] .runner-canvas { filter: invert(1); }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .runner-canvas { filter: invert(1); }
  }
  body.inverted .runner-canvas { filter: invert(1); }
  :root[data-theme="dark"] body.inverted .runner-canvas { filter: none; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) body.inverted .runner-canvas { filter: none; }
  }
  .interstitial-wrapper .controller {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    background: transparent;
    cursor: pointer;
  }
</style>
