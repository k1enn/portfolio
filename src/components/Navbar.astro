---
// Anchor links scroll to home sections (smooth-scroll via data-nav-jump).
const NAV_LINKS = [
  { id: "home", label: "Home" },
  { id: "projects", label: "Timeline" },
  { id: "tech", label: "Tech" },
  { id: "contact", label: "Contact" },
];

// Route links navigate to real pages (no data-nav-jump).
const ROUTE_LINKS = [
  { href: "/blog", label: "Blog" },
];
---

<nav class="navbar" aria-label="Primary">
  <div class="navbar-container">
    <a href="/#home" class="navbar-logo" aria-label="k1en home" data-nav-jump="home">k1en</a>

    <div class="nav-right">
      <ul id="primary-nav-menu" class="nav-menu">
        {NAV_LINKS.map((link) => (
          <li class="nav-item">
            <a href={`/#${link.id}`} class="nav-link" data-nav-jump={link.id}>{link.label}</a>
          </li>
        ))}
        {ROUTE_LINKS.map((link) => (
          <li class="nav-item">
            <a href={link.href} class="nav-link">{link.label}</a>
          </li>
        ))}
      </ul>

      <button
        type="button"
        class="theme-toggle"
        data-theme-toggle
        aria-label="Theme: system. Click to switch."
        title="Theme: system. Click to switch."
      >
        <svg data-theme-icon="system" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="4" width="18" height="13" rx="1"></rect>
          <path d="M8 21h8M12 17v4" stroke-linecap="round"></path>
        </svg>
        <svg data-theme-icon="light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-linecap="round"></path>
        </svg>
        <svg data-theme-icon="dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-linejoin="round"></path>
        </svg>
      </button>

      <button
        type="button"
        class="menu-icon"
        data-menu-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="primary-nav-menu"
      >
        <div class="hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </button>
    </div>
  </div>
</nav>

<script>
  type ThemeMode = "light" | "dark" | "system";

  const readStoredTheme = (): ThemeMode => {
    try {
      const v = localStorage.getItem("theme");
      return v === "light" || v === "dark" ? v : "system";
    } catch {
      return "system";
    }
  };

  const applyTheme = (mode: ThemeMode) => {
    const root = document.documentElement;
    if (mode === "system") {
      delete root.dataset.theme;
      try { localStorage.removeItem("theme"); } catch {}
    } else {
      root.dataset.theme = mode;
      try { localStorage.setItem("theme", mode); } catch {}
    }
  };

  const updateLabel = (mode: ThemeMode) => {
    const btn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
    if (!btn) return;
    const label = `Theme: ${mode}. Click to switch.`;
    btn.setAttribute("aria-label", label);
    btn.setAttribute("title", label);
  };

  let theme: ThemeMode = readStoredTheme();
  updateLabel(theme);

  document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
    theme = theme === "light" ? "dark" : theme === "dark" ? "system" : "light";
    applyTheme(theme);
    updateLabel(theme);
  });

  const menu = document.getElementById("primary-nav-menu");
  const menuBtn = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  menuBtn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("active") ?? false;
    menuBtn.setAttribute("aria-expanded", String(open));
    menuBtn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });

  document.querySelectorAll<HTMLAnchorElement>("[data-nav-jump]").forEach((a) => {
    a.addEventListener("click", (e) => {
      const id = a.dataset.navJump;
      if (!id) return;
      const el = document.getElementById(id);
      if (!el) return;
      e.preventDefault();
      window.scrollTo({ top: el.offsetTop - 72 });
      menu?.classList.remove("active");
      menuBtn?.setAttribute("aria-expanded", "false");
      menuBtn?.setAttribute("aria-label", "Open menu");
    });
  });
</script>
