---
import SectionHeading from "./SectionHeading.astro";
import TimelineEntry from "./TimelineEntry.astro";
import type { TimelineItem } from "./TimelineEntry.astro";
import timelineData from "../data/timeline.json";

// Sort newest-first. Ongoing ("present") floats to the top; tie-break by start desc.
const sortKey = (i: TimelineItem) => (i.end === "present" ? "9999-99" : i.end || i.start);
const items = [...(timelineData as TimelineItem[])].sort((a, b) => {
  const ka = sortKey(a);
  const kb = sortKey(b);
  if (ka !== kb) return kb.localeCompare(ka);
  return b.start.localeCompare(a.start);
});

// Show the first few; reveal the rest behind a "Show More" toggle.
const initialCount = 4;
const hasMore = items.length > initialCount;
---

<section id="projects" aria-labelledby="projects-heading" class="timeline-section">
  <div class="container">
    <SectionHeading id="projects-heading" index={1}>Timeline</SectionHeading>

    <div class="timeline-meta-row">
      <span class="timeline-count">Entries: {String(items.length).padStart(2, "0")}</span>
      <span class="timeline-tag">
        <span class="timeline-tag-dot" aria-hidden="true"></span>
        Work · Education · Projects
      </span>
    </div>

    <ol class="timeline" data-timeline data-initial-count={initialCount}>
      {items.map((item, i) => (
        <TimelineEntry
          item={item}
          hidden={hasMore && i >= initialCount}
          railEnd={hasMore && i === initialCount - 1}
        />
      ))}
    </ol>

    {hasMore && (
      <div class="timeline-actions">
        <button
          type="button"
          class="timeline-more-btn"
          data-tl-more
          aria-expanded="false"
          aria-controls="projects"
        >
          <span data-label-more>Show More ({items.length - initialCount})</span>
          <span data-label-less hidden>Show Less</span>
        </button>
      </div>
    )}
  </div>
</section>

<script>
  // Progressive reveal: entries are visible by default (no-JS / reduced-motion safe).
  // With JS + motion allowed, fade them in as they enter the viewport.
  const entries = document.querySelectorAll<HTMLElement>('[data-timeline] [data-reveal]');
  const motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

  if (motionOk && 'IntersectionObserver' in window && entries.length) {
    const io = new IntersectionObserver((records, obs) => {
      for (const rec of records) {
        if (rec.isIntersecting) {
          (rec.target as HTMLElement).dataset.reveal = 'in';
          obs.unobserve(rec.target);
        }
      }
    }, { rootMargin: '0px 0px -10% 0px' });
    entries.forEach((el) => io.observe(el));
  } else {
    entries.forEach((el) => el.removeAttribute('data-reveal'));
  }

  // Show More / Show Less toggle.
  const feed = document.querySelector<HTMLElement>('[data-timeline]');
  const btn = document.querySelector<HTMLButtonElement>('[data-tl-more]');
  if (feed && btn) {
    const initial = Number(feed.dataset.initialCount) || 4;
    const rows = Array.from(feed.querySelectorAll<HTMLElement>('.tl-entry'));
    const labelMore = btn.querySelector<HTMLElement>('[data-label-more]');
    const labelLess = btn.querySelector<HTMLElement>('[data-label-less]');
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const next = !expanded;
      btn.setAttribute('aria-expanded', String(next));
      rows.forEach((el, i) => {
        if (i >= initial) el.toggleAttribute('data-tl-hidden', !next);
        if (i === initial - 1) el.toggleAttribute('data-tl-rail-end', !next);
      });
      labelMore?.toggleAttribute('hidden', next);
      labelLess?.toggleAttribute('hidden', !next);
      if (!next) feed.closest('section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
</script>

<style>
  .timeline-section {
    padding-top: 3rem;
    padding-bottom: 3rem;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }
  .timeline-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .timeline-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
  }
  .timeline-tag-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--fg);
  }
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .timeline-actions {
    display: flex;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .timeline-more-btn {
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 12px 26px;
    background: var(--surface);
    color: var(--fg);
    border: 2px solid var(--border);
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .timeline-more-btn:hover,
  .timeline-more-btn:focus-visible {
    background: var(--surface-hover);
    outline: none;
  }
  @media (min-width: 768px) {
    .timeline-section { padding-top: 4.5rem; padding-bottom: 4.5rem; }
  }
</style>
