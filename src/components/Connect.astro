---
import SectionHeading from "./SectionHeading.astro";
import { FaLinkedin, FaGithub, FaYoutube, FaDiscord, FaFacebook } from "react-icons/fa";
import { SiCodeforces, SiLeetcode } from "react-icons/si";

const SOCIAL_LINKS = [
  { url: "https://linkedin.com/in/k1enn", Icon: FaLinkedin, label: "LinkedIn", handle: "@k1enn" },
  { url: "https://www.github.com/k1enn", Icon: FaGithub, label: "GitHub", handle: "@k1enn" },
  { url: "https://www.youtube.com/@iamk1en", Icon: FaYoutube, label: "YouTube", handle: "@iamk1en" },
  { url: "https://codeforces.com/profile/dinhtrungkien", Icon: SiCodeforces, label: "Codeforces", handle: "dinhtrungkien" },
  { url: "https://www.leetcode.com/iamk1en", Icon: SiLeetcode, label: "LeetCode", handle: "iamk1en" },
  { url: "https://discord.gg/Wk9rmt83v8", Icon: FaDiscord, label: "Discord", handle: "k1en" },
  { url: "https://www.facebook.com/imnotk1en", Icon: FaFacebook, label: "Facebook", handle: "imnotk1en" },
];
---

<section id="connect" aria-labelledby="connect-heading" class="connect-section">
  <div class="container">
    <SectionHeading id="connect-heading" index={2}>Connect</SectionHeading>

    <div class="connect-grid reveal">
      {
        SOCIAL_LINKS.map(({ url, Icon, label, handle }) => (
          <a
            class="connect-card"
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${label} — ${handle} (opens in new tab)`}
          >
            <div class="connect-top">
              <Icon className="connect-icon" aria-hidden="true" />
              <span class="connect-arrow">↗</span>
            </div>
            <div class="connect-body">
              <span class="connect-label">{label}</span>
              <span class="connect-handle">{handle}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .connect-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
    background: #FFF;
    border-top: 2px solid #000;
  }
  .connect-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border: 2px solid #000;
    background: #FFF;
    box-shadow: var(--shadow-brutal);
  }
  .connect-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 16px;
    min-height: 140px;
    background: #FFF;
    color: #000;
    border-right: 2px solid #000;
    border-bottom: 2px solid #000;
    transition: all 0.12s ease-out;
  }
  .connect-card:hover, .connect-card:focus-visible {
    background: #000;
    color: #FFF;
    outline: none;
    text-decoration: none;
  }
  .connect-top {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .connect-icon { font-size: 28px; }
  .connect-arrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  .connect-body { display: flex; flex-direction: column; }
  .connect-label {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .connect-handle {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    margin-top: 4px;
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  @media (min-width: 640px) {
    .connect-grid { grid-template-columns: repeat(3, 1fr); }
    .connect-card { padding: 20px; min-height: 160px; }
    .connect-icon { font-size: 32px; }
    .connect-label { font-size: 1.1rem; }
  }
  @media (min-width: 768px) {
    .connect-section { padding-top: 6rem; padding-bottom: 6rem; }
    .connect-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
