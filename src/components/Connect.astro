---
import SectionHeading from "./SectionHeading.astro";
import { SOCIAL_ICONS } from "../utils/social-icons.jsx";
import profile from "../data/profile.json";

const EMAIL = profile.email;
const SOCIAL_LINKS = profile.socials.map((s) => ({ ...s, Icon: SOCIAL_ICONS[s.icon] }));
---

<section id="contact" aria-labelledby="contact-heading" class="contact-section">
  <div class="container">
    <SectionHeading id="contact-heading" index={5}>Contact</SectionHeading>

    <a
      class="email-cta"
      href={`mailto:${EMAIL}?subject=${encodeURIComponent(`Hello ${profile.name}`)}`}
      aria-label={`Email ${profile.name} at ${EMAIL}`}
    >
      <div class="email-cta-left">
        <span class="email-eyebrow">Direct · Best for work</span>
        <span class="email-headline">Email Me</span>
        <span class="email-address">{EMAIL}</span>
      </div>
      <div class="email-cta-right" aria-hidden="true">
        <span class="email-arrow">↗</span>
      </div>
    </a>

    <div class="contact-divider" aria-hidden="true">
      <span class="contact-divider-line"></span>
      <span class="contact-divider-text">Or find me on</span>
      <span class="contact-divider-line"></span>
    </div>

    <div class="contact-grid">
      {
        SOCIAL_LINKS.map(({ url, Icon, label, handle }) => (
          <a
            class="contact-card"
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${label} — ${handle} (opens in new tab)`}
          >
            <div class="contact-top">
              <Icon className="contact-icon" aria-hidden="true" />
              <span class="contact-arrow">↗</span>
            </div>
            <div class="contact-body">
              <span class="contact-label">{label}</span>
              <span class="contact-handle">{handle}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-top: 3rem;
    padding-bottom: 3rem;
    background: var(--panel);
    border-top: 1px solid var(--line);
  }
  .email-cta {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    padding: 18px;
    background: var(--bg);
    color: var(--fg);
    border: 2px solid var(--border);
    margin-bottom: 1.75rem;
    transition: background 120ms ease, color 120ms ease;
  }
  .email-cta:hover, .email-cta:focus-visible {
    background: var(--fg);
    color: var(--bg);
    outline: none;
    text-decoration: none;
  }
  .email-cta-left {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  .email-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .email-cta:hover .email-eyebrow,
  .email-cta:focus-visible .email-eyebrow { color: var(--bg); }
  .email-headline {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 700;
  }
  .email-address {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    word-break: break-all;
  }
  .email-cta-right {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
    flex-shrink: 0;
  }
  .email-icon { font-size: 36px; }
  .email-arrow {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
  }
  @media (min-width: 640px) {
    .email-cta { padding: 24px 28px; }
    .email-icon { font-size: 44px; }
  }
  @media (min-width: 768px) {
    .email-cta { padding: 28px 32px; margin-bottom: 2rem; }
    .email-icon { font-size: 52px; }
  }

  .contact-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 1.5rem;
  }
  .contact-divider-line {
    flex: 1;
    height: 2px;
    background: var(--border);
  }
  .contact-divider-text {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
    background: var(--surface);
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 14px;
    min-height: 112px;
    background: var(--surface);
    color: var(--fg);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    transition: background 0.15s ease;
  }
  .contact-card:hover, .contact-card:focus-visible {
    background: var(--surface-hover);
    outline: none;
    text-decoration: none;
  }
  .contact-top {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .contact-icon { font-size: 28px; }
  .contact-arrow {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
  }
  .contact-body { display: flex; flex-direction: column; }
  .contact-label {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    line-height: 1;
    font-weight: 700;
  }
  .contact-handle {
    font-size: 0.78rem;
    margin-top: 4px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .contact-card:hover .contact-handle,
  .contact-card:focus-visible .contact-handle { color: var(--fg); }
  @media (min-width: 640px) {
    .contact-grid { grid-template-columns: repeat(3, 1fr); }
    .contact-card { padding: 18px; min-height: 128px; }
    .contact-icon { font-size: 32px; }
    .contact-label { font-size: 1.1rem; }
  }
  @media (min-width: 768px) {
    .contact-section { padding-top: 4.5rem; padding-bottom: 4.5rem; }
    .contact-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
