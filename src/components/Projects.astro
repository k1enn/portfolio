---
import SectionHeading from "./SectionHeading.astro";
import ProjectCard from "./ProjectCard.astro";
import projectsData from "../data/projects.json";

const totalCount = projectsData.length;
const initialCount = 4;
const hasMore = totalCount > initialCount;
---

<section id="projects" aria-labelledby="projects-heading" class="projects-section">
  <div class="container">
    <SectionHeading id="projects-heading" index={1}>Projects</SectionHeading>

    <div class="projects-meta-row">
      <span class="projects-count">
        Count: {String(totalCount).padStart(2, "0")}
      </span>
      <span class="projects-tag">
        <span class="projects-tag-dot" aria-hidden="true"></span>
        Selected Work
      </span>
    </div>

    <div id="projects-grid" class="projects-grid" data-projects-grid data-initial-count={initialCount}>
      {projectsData.map((project, i) => (
        <div class="project-card-wrap" data-hidden={i >= initialCount ? "true" : "false"}>
          <ProjectCard project={project} index={i} />
        </div>
      ))}
    </div>

    {hasMore && (
      <div class="projects-actions">
        <button
          type="button"
          class="load-more-btn"
          data-load-more
          aria-expanded="false"
          aria-controls="projects-grid"
        >
          <span data-label-more>Load More ({totalCount - initialCount})</span>
          <span data-label-less hidden>Show Less</span>
        </button>
      </div>
    )}
  </div>
</section>

<script>
  const grid = document.querySelector<HTMLElement>("[data-projects-grid]");
  const btn = document.querySelector<HTMLButtonElement>("[data-load-more]");
  if (grid && btn) {
    const labelMore = btn.querySelector<HTMLElement>("[data-label-more]");
    const labelLess = btn.querySelector<HTMLElement>("[data-label-less]");
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      const next = !expanded;
      btn.setAttribute("aria-expanded", String(next));
      grid.querySelectorAll<HTMLElement>(".project-card-wrap[data-hidden]").forEach((el) => {
        if (next) el.dataset.hidden = "false";
        else {
          const idx = Array.from(el.parentElement!.children).indexOf(el);
          const initial = Number(grid.dataset.initialCount || 4);
          el.dataset.hidden = idx >= initial ? "true" : "false";
        }
      });
      labelMore?.toggleAttribute("hidden", next);
      labelLess?.toggleAttribute("hidden", !next);
      if (!next) {
        document.getElementById("projects")?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  }
</script>

<style>
  .projects-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }
  .projects-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .projects-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
  }
  .projects-tag-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--fg);
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .project-card-wrap[data-hidden="true"] {
    display: none;
  }
  .projects-actions {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .load-more-btn {
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 14px 28px;
    background: var(--surface);
    color: var(--fg);
    border: 2px solid var(--border);
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .load-more-btn:hover,
  .load-more-btn:focus-visible {
    background: var(--surface-hover);
    outline: none;
  }
  @media (min-width: 768px) {
    .projects-section { padding-top: 6rem; padding-bottom: 6rem; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }
</style>
