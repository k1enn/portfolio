---
import SectionHeading from "./SectionHeading.astro";
import ProjectCard from "./ProjectCard.astro";
import projectsData from "../data/projects.json";
import { RiArrowRightLine } from "react-icons/ri";

const featured = projectsData.slice(0, 4);
const totalCount = projectsData.length;
---

<section id="projects" aria-labelledby="projects-heading" class="projects-section">
  <div class="container">
    <SectionHeading id="projects-heading" index={3}>Projects</SectionHeading>

    <div class="projects-meta-row">
      <span class="projects-count">
        Showing {featured.length} of {totalCount}
      </span>
      <span class="projects-tag">
        <span class="projects-tag-dot" aria-hidden="true"></span>
        Selected Work
      </span>
    </div>

    <div class="projects-grid">
      {featured.map((project, i) => <ProjectCard project={project} index={i} />)}
    </div>

    <div class="projects-cta">
      <a class="btn-brutal btn-brutal-dark reveal" href="/projects">
        View all projects
        <RiArrowRightLine size={18} />
      </a>
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
    background: #FFF;
    border-top: 2px solid #000;
  }
  .projects-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .projects-count {}
  .projects-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
  }
  .projects-tag-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: #000;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .projects-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .btn-brutal {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 2px solid #000;
    box-shadow: var(--shadow-brutal);
    padding: 12px 20px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.12s ease-out;
    cursor: pointer;
    text-decoration: none;
  }
  .btn-brutal-dark {
    background: #000;
    color: #FFF;
  }
  .btn-brutal-dark:hover {
    background: #FFF;
    color: #000;
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-brutal-lg);
  }
  .btn-brutal:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }
  @media (min-width: 768px) {
    .projects-section { padding-top: 6rem; padding-bottom: 6rem; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .projects-cta { margin-top: 3.5rem; }
    .btn-brutal { padding: 16px 28px; font-size: 1rem; }
  }
</style>
