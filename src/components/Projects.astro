---
import SectionHeading from "./SectionHeading.astro";
import ProjectCard from "./ProjectCard.astro";
import projectsData from "../data/projects.json";

const totalCount = projectsData.length;
---

<section id="projects" aria-labelledby="projects-heading" class="projects-section">
  <div class="container">
    <SectionHeading id="projects-heading" index={1}>Projects</SectionHeading>

    <div class="projects-meta-row">
      <span class="projects-count">
        Count: {String(totalCount).padStart(2, "0")}
      </span>
      <span class="projects-tag">
        <span class="projects-tag-dot" aria-hidden="true"></span>
        Selected Work
      </span>
    </div>

    <div class="projects-grid">
      {projectsData.map((project, i) => <ProjectCard project={project} index={i} />)}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
    background: var(--bg);
    border-top: 2px solid var(--border);
  }
  .projects-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .projects-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
  }
  .projects-tag-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--fg);
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) {
    .projects-section { padding-top: 6rem; padding-bottom: 6rem; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }
</style>
