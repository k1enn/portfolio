---
import { RiArrowRightUpLine } from "react-icons/ri";
import type { TimelineItem } from "./TimelineEntry.astro";

export interface Props {
  item: TimelineItem;
  hidden?: boolean;
}

const { item, hidden = false } = Astro.props;

// "2024-09" -> "Sep 2024"; "present" -> "Present"
const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
function fmt(value?: string): string {
  if (!value) return "";
  if (value === "present") return "Present";
  const [y, m] = value.split("-");
  const mi = Number(m) - 1;
  return MONTHS[mi] ? `${MONTHS[mi]} ${y}` : y;
}
const dateLabel = item.end ? `${fmt(item.start)} – ${fmt(item.end)}` : fmt(item.start);
const dateTimeAttr = item.end && item.end !== "present" ? item.end : item.start;

// Responsive thumbnail (matches -400w/-800w variants).
const img = item.image;
const isVariant = !!img && img.startsWith("/images/") && img.endsWith(".webp");
const base = isVariant ? img!.slice(0, -".webp".length) : "";
const srcset = isVariant ? `${base}-400w.webp 400w, ${base}-800w.webp 800w, ${img} 1280w` : undefined;
const sizes = srcset ? "(min-width: 720px) 680px, 100vw" : undefined;
const displaySrc = isVariant ? `${base}-800w.webp` : img;

const Tag = item.link ? "a" : "div";
const linkProps = item.link
  ? {
      href: item.link,
      target: "_blank",
      rel: "noopener noreferrer",
      "aria-label": `${item.title} (opens in new tab)`,
    }
  : {};
---

<li class="proj-item" data-proj-hidden={hidden ? "true" : undefined}>
  <Tag class="proj-card" {...linkProps}>
    {displaySrc && (
      <div class="proj-thumb-wrap">
        <img
          class="proj-thumb"
          src={displaySrc}
          srcset={srcset}
          sizes={sizes}
          alt={`${item.title} preview`}
          loading="lazy"
          decoding="async"
          width="800"
          height="450"
        />
      </div>
    )}

    <div class="proj-body">
      <div class="proj-meta">
        <span class="proj-badge">Project</span>
        {item.org && <span class="proj-org">{item.org}</span>}
        <time class="proj-date" datetime={dateTimeAttr}>{dateLabel}</time>
      </div>

      <h3 class="proj-title">
        <span>{item.title}</span>
        {item.link && (
          <span class="proj-arrow" aria-hidden="true"><RiArrowRightUpLine size={20} /></span>
        )}
      </h3>

      <p class="proj-desc">{item.description}</p>

      {item.tags && item.tags.length > 0 && (
        <ul class="proj-tags">
          {item.tags.map((tag) => (
            <li class="proj-tag">{tag}</li>
          ))}
        </ul>
      )}
    </div>
  </Tag>
</li>

<style>
  .proj-item { margin: 0; }
  .proj-item[data-proj-hidden] { display: none; }

  .proj-card {
    display: block;
    background: var(--surface);
    color: var(--fg);
    border: 2px solid var(--border);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  a.proj-card:hover,
  a.proj-card:focus-visible {
    background: var(--surface-hover);
    outline: none;
    text-decoration: none;
  }
  a.proj-card:focus-visible { outline: 3px solid var(--fg); outline-offset: 2px; }

  .proj-thumb-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg);
    border-bottom: 2px solid var(--border);
  }
  .proj-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  a.proj-card:hover .proj-thumb { transform: scale(1.03); }

  .proj-body { padding: 18px; }

  .proj-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .proj-badge {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 2px solid var(--border);
    padding: 2px 8px;
    color: var(--fg);
  }
  .proj-org {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--muted-strong);
  }
  .proj-date {
    font-size: 0.76rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-left: auto;
  }

  .proj-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
    font-weight: 700;
    word-break: break-word;
  }
  .proj-arrow { display: inline-flex; flex-shrink: 0; color: var(--muted); }
  a.proj-card:hover .proj-arrow,
  a.proj-card:focus-visible .proj-arrow { color: var(--fg); }

  .proj-desc {
    margin-top: 10px;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--fg);
  }
  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
  }
  .proj-tag {
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border: 1px solid var(--muted);
    color: var(--muted-strong);
    padding: 3px 9px;
  }
  @media (min-width: 640px) {
    .proj-body { padding: 22px 24px; }
    .proj-title { font-size: 1.5rem; }
  }
</style>
