---
import { RiArrowRightUpLine } from "react-icons/ri";

export interface Project {
  title: string;
  description: string;
  image: string;
  link: string;
  tags?: string[];
  year?: string;
  stack?: string;
}

export interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const number = String(index + 1).padStart(2, "0");

const buildSrcset = (src: string) => {
  if (!src.startsWith("/images/") || !src.endsWith(".webp")) return undefined;
  const base = src.slice(0, -".webp".length);
  return `${base}-480w.webp 480w, ${base}-800w.webp 800w, ${src} 1280w`;
};
const srcset = buildSrcset(project.image);
const sizes = srcset ? "(min-width: 768px) 50vw, 100vw" : undefined;
---

<a
  class="project-card"
  href={project.link}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${project.title} — open on GitHub (new tab)`}
>
  <div class="project-card-inner">
    <div class="project-thumb-wrap">
      <img
        class="project-thumb"
        src={project.image}
        srcset={srcset}
        sizes={sizes}
        alt={project.title ? `${project.title} preview` : ""}
        loading="lazy"
        decoding="async"
        width="1280"
        height="720"
      />
      <span class="project-meta">{number}</span>
    </div>

    <div class="project-body">
      <div class="project-head">
        <h3 class="project-title">{project.title}</h3>
        <span class="project-arrow" aria-hidden="true">
          <RiArrowRightUpLine size={22} />
        </span>
      </div>

      {
        project.tags && project.tags.length > 0 && (
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="project-tag">{tag}</span>
            ))}
          </div>
        )
      }

      <p class="project-description">{project.description}</p>
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    height: 100%;
    color: var(--fg);
    text-decoration: none;
  }
  .project-card:focus-visible { outline: none; }
  .project-card-inner {
    background: var(--bg);
    border: 2px solid var(--border);
    height: 100%;
    display: flex;
    flex-direction: column;
    color: var(--fg);
  }
  .project-card:hover .project-card-inner,
  .project-card:focus-visible .project-card-inner {
    background: var(--fg);
    color: var(--bg);
  }
  .project-thumb-wrap {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    overflow: hidden;
    border-bottom: 2px solid var(--border);
    background: var(--bg);
  }
  .project-thumb {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .project-meta {
    position: absolute;
    top: 0;
    left: 0;
    background: var(--bg);
    color: var(--fg);
    border-right: 2px solid var(--border);
    border-bottom: 2px solid var(--border);
    padding: 4px 12px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    flex: 1;
  }
  .project-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .project-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    word-break: break-word;
    margin: 0;
    font-weight: 700;
  }
  .project-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 40px;
    border: 2px solid currentColor;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .project-tag {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 2px solid currentColor;
    padding: 4px 8px;
  }
  .project-description {
    font-size: 0.95rem;
    line-height: 1.5;
  }
  @media (min-width: 640px) {
    .project-body { padding: 20px; }
    .project-title { font-size: 1.5rem; }
  }
</style>
