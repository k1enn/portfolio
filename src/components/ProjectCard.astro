---
import { RiArrowRightUpLine } from "react-icons/ri";

export interface Project {
  title: string;
  description: string;
  image: string;
  link: string;
  tags?: string[];
  year?: string;
  stack?: string;
}

export interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const number = String(index + 1).padStart(2, "0");
---

<a
  class="project-card reveal"
  href={project.link}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${project.title} — open on GitHub (new tab)`}
>
  <div class="project-card-inner">
    <div class="project-thumb-wrap">
      <img
        class="project-thumb"
        src={project.image}
        alt={project.title ? `${project.title} preview` : ""}
        loading="lazy"
      />
      <span class="project-meta">{number}</span>
    </div>

    <div class="project-body">
      <div class="project-head">
        <h3 class="project-title">{project.title}</h3>
        <span class="project-arrow" aria-hidden="true">
          <RiArrowRightUpLine size={22} />
        </span>
      </div>

      {
        project.tags && project.tags.length > 0 && (
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="project-tag">{tag}</span>
            ))}
          </div>
        )
      }

      <p class="project-description">{project.description}</p>

      {
        (project.year || project.stack) && (
          <div class="project-footer-row">
            {project.year && <span>{project.year}</span>}
            {project.stack && <span>{project.stack}</span>}
          </div>
        )
      }
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    height: 100%;
    color: #000;
    text-decoration: none;
  }
  .project-card:focus-visible { outline: none; }
  .project-card-inner {
    background: #FFF;
    border: 2px solid #000;
    box-shadow: var(--shadow-brutal);
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: transform 0.12s ease-out, box-shadow 0.12s ease-out, background 0.12s ease-out, color 0.12s ease-out;
  }
  .project-card:hover .project-card-inner,
  .project-card:focus-visible .project-card-inner {
    transform: translate(-4px, -4px);
    box-shadow: var(--shadow-brutal-lg);
    background: #000;
    color: #FFF;
  }
  .project-thumb-wrap {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    overflow: hidden;
    border-bottom: 2px solid #000;
    background: #F5F5F5;
  }
  .project-thumb {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease-out;
  }
  .project-card:hover .project-thumb { transform: scale(1.03); }
  .project-meta {
    position: absolute;
    top: 0;
    left: 0;
    background: #FFF;
    color: #000;
    border-right: 2px solid #000;
    border-bottom: 2px solid #000;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    flex: 1;
  }
  .project-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .project-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    word-break: break-word;
    margin: 0;
  }
  .project-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 40px;
    border: 2px solid currentColor;
    transition: background 0.12s ease-out, color 0.12s ease-out;
  }
  .project-card:hover .project-arrow {
    background: #FFF;
    color: #000;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 2px solid currentColor;
    padding: 4px 8px;
  }
  .project-description {
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .project-footer-row {
    margin-top: auto;
    padding-top: 12px;
    border-top: 2px solid currentColor;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  @media (min-width: 640px) {
    .project-body { padding: 20px; }
    .project-title { font-size: 1.5rem; }
    .project-description { font-size: 1rem; }
  }
</style>
