---
import Layout from "./Layout.astro";
import Navbar from "../components/Navbar.astro";
import Comments from "../components/Comments.astro";
import { slugify } from "../utils/slugify";
import "../styles/prose.css";

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  tags?: string[];
  // Absolute og:image URL from the post body, or null to omit it entirely.
  image?: string | null;
}

const { title, description, publishDate, updatedDate, tags = [], image } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
const iso = (d: Date) => d.toISOString().slice(0, 10);
---

<Layout title={`${title} — Trung Kien`} description={description} image={image}>
  <Navbar />
  <main>
    <article class="post measure">
      <a class="post-back" href="/blog">← All posts</a>

      <header class="post-header">
        <div class="post-meta">
          <time datetime={iso(publishDate)}>{fmt(publishDate)}</time>
          {updatedDate && <span class="post-updated">· updated {fmt(updatedDate)}</span>}
        </div>
        <h1 class="post-heading">{title}</h1>
        {tags.length > 0 && (
          <ul class="post-header-tags">
            {tags.map((tag) => (
              <li><a class="post-tag" href={`/tags/${slugify(tag)}`}>{tag}</a></li>
            ))}
          </ul>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>

    <Comments />
  </main>
</Layout>

<style>
  .post {
    padding-top: clamp(104px, 12vw, 140px);
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }
  .post-back {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }
  .post-back:hover, .post-back:focus-visible { color: var(--fg); outline: none; }
  .post-header {
    border-bottom: 2px solid var(--border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }
  .post-meta {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .post-updated { margin-left: 4px; }
  .post-heading {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 6vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    font-weight: 700;
    margin-top: 10px;
  }
  .post-header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
  }
  .post-tag {
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border: 1px solid var(--muted);
    color: var(--muted);
    padding: 3px 8px;
  }
  .post-tag:hover, .post-tag:focus-visible {
    border-color: var(--fg);
    color: var(--fg);
    outline: none;
  }
</style>
