---
import "../styles/global.css";
import "../styles/navbar.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Trung Kien — Portfolio",
  description = "Trung Kien (k1en) — passionate programmer and future back-end developer from Vietnam. Explore projects, technologies, and connect.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#FFFFFF" />
    <meta name="color-scheme" content="light" />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Trung Kien Portfolio" />
    <meta property="og:description" content="Passionate programmer and future back-end developer from Vietnam." />
    <meta property="og:url" content="https://k1en.site" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Trung Kien Portfolio" />
    <meta name="twitter:description" content="Passionate programmer and future back-end developer from Vietnam." />

    <link rel="apple-touch-icon" href="/logo192.png" />
    <link rel="manifest" href="/manifest.json" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    <a href="#header" class="skip-link">Skip to content</a>
    <slot />

    <script is:inline>
      // Reveal-on-scroll utility for static Astro components
      (function () {
        if (typeof window === "undefined") return;
        const nodes = document.querySelectorAll(".reveal, .reveal-left, .reveal-underline");
        if (!nodes.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "-40px 0px" }
        );
        nodes.forEach((n) => io.observe(n));
      })();
    </script>
  </body>
</html>
